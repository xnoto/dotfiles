#!/bin/bash
# Managed by chezmoi — refreshes fontconfig cache after font/fontconfig changes
# Hash triggers (script runs when any of these change):
# - Px437_IBM_VGA_8x16.ttf: {{ include "dot_local/share/fonts/Px437_IBM_VGA_8x16.ttf" | sha256sum }}
# - Px437_IBM_VGA_9x16.ttf: {{ include "dot_local/share/fonts/Px437_IBM_VGA_9x16.ttf" | sha256sum }}
# - FSEX.ttf: {{ include "dot_local/share/fonts/FSEX.ttf" | sha256sum }}
# - 99-terminal-fonts.conf: {{ include "dot_config/fontconfig/conf.d/99-terminal-fonts.conf" | sha256sum }}
set -euo pipefail

{{- if eq .chezmoi.os "linux" }}
# Refresh fontconfig cache for bitmap fonts and config changes
if command -v fc-cache &>/dev/null; then
  echo "Refreshing fontconfig cache..."
  fc-cache -fv "{{ .chezmoi.homeDir }}/.local/share/fonts" 2>/dev/null || true
fi
{{- end }}
